{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../.worker-dist",
    "rootDir": "..",
    "module": "commonjs",
    "target": "ES2022",
    "moduleResolution": "node",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "isolatedModules": false,
    "baseUrl": "..",
    "incremental": false,
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "files": ["./main.ts", "./jobs/traffic-monitor/job.ts"],
  "exclude": [
    "../node_modules",
    "../.next",
    "../src/**/*.tsx",
    "../src/**/ui/**",
    "../src/features/security-assets/**",
    "../src/features/sing-box/inbounds/ui/**",
    "../src/shared/ui/**",
    "../src/shared/hooks/**",
    "../src/shared/assets/**"
  ]
}
