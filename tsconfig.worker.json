{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": ".worker-dist",
    "rootDir": "src",
    "module": "commonjs",
    "target": "ES2022",
    "moduleResolution": "node",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "isolatedModules": false,
    "incremental": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/server/**/*.ts",
    "src/shared/**/*.ts",
    "src/features/**/server/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "src/**/*.tsx", "src/**/ui/**"]
}
